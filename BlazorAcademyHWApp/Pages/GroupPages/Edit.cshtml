@page
@model BlazorAcademyHWApp.Pages.GroupPages.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Group</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Group.Id" />
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Group.Name" class="control-label"></label>
                <input asp-for="Group.Name" class="form-control" aria-required="true"/>
                <span asp-validation-for="Group.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Group.DirectionId" class="control-label"></label>
                <input asp-for="Group.DirectionId" class="form-control" />
                <span asp-validation-for="Group.DirectionId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Group.Direction" class="control-label"></label>
                <input asp-for="Group.Direction" class="form-control" />
                <span asp-validation-for="Group.Direction" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Group.YearOfStudy" class="control-label"></label>
                <input asp-for="Group.YearOfStudy" class="form-control" />
                <span asp-validation-for="Group.YearOfStudy" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
