@page
@model BlazorAcademyHWApp.Pages.DisciplinePages.IndexModel

<h1>Дисциплины</h1>

<form method="get">
    <div class="form-group">
        <label for="sortOrder">Сортировка:</label>
        <select name="sortOrder" class="form-control" asp-for="CurrentSort" onchange="this.form.submit()">
            <option value="id_asc">ID (возр.)</option>
            <option value="id_desc">ID (убыв.)</option>
            <option value="name_asc">Название (А-Я)</option>
            <option value="name_desc">Название (Я-А)</option>
            <option value="teacher_asc">Преподаватель (А-Я)</option>
            <option value="teacher_desc">Преподаватель (Я-А)</option>
            <option value="credits_asc">Кредиты (возр.)</option>
            <option value="credits_desc">Кредиты (убыв.)</option>
        </select>
    </div>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название дисциплины</th>
            <th>Преподаватель</th>
            <th>Кредиты</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var discipline in Model.Disciplines)
        {
            <tr>
                <td>@discipline.Id</td>
                <td>@discipline.Name</td>
                <td>@(discipline.Teacher != null ? $"{discipline.Teacher.LastName} {discipline.Teacher.FirstName}" : "—")</td>
                <td>@(discipline.Credits?.ToString() ?? "—")</td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-route-pageNumber="@i" asp-route-sortOrder="@Model.CurrentSort">@i</a>
                </li>
            }
        </ul>
    </nav>
}